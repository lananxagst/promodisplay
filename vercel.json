{
    "version": 2,
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/dist",
    "functions": {
        "api/index.js": {
            "memory": 512,
            "maxDuration": 30
        }
    },
    "rewrites": [
        { "source": "/api/:path*", "destination": "/api/index.js" },
        { "source": "/:path*", "destination": "/index.html" }
    ]
}